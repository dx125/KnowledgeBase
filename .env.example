# =============================================================================
# Single environment file for the whole project. Copy to ".env" and fill in.
#   cp .env.example .env
#
# Vite (web app) only ever exposes variables prefixed with VITE_ to the browser.
# The other values stay server-side (used by scripts/deploy.mjs) and are NEVER
# bundled into the client, even though they live in the same file.
# =============================================================================

# --- Browser app -------------------------------------------------------------
# supabase-js uses these for AUTH ONLY (login/session). All data goes through the
# Edge Function API (URL derived as <VITE_SUPABASE_URL>/functions/v1/kb); the
# browser never queries the database directly.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Data deploy (server-side only) ------------------------------------------
# Postgres connection string with transaction support.
# Supabase Dashboard -> Connect -> "Session pooler" (port 5432). NOT "Transaction" (6543).
# Looks like: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Absolute path to the unzipped dataset folder (contains kb_cards.json, locale_*.json,
# glossary.json, entity_index.json, ...).
DATASET_DIR=C:/Users/alezd/Downloads/kb_dataset_uy_v5_quality/kb_dataset_uy_v5_quality
